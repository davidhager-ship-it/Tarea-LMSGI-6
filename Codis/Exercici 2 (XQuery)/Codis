2.12. Retorna el número de xecs (number) creats pels clients amb el cognom "Atelier graphique". Utilitza una consulta niada per obtenir el customerNumber del client associat i filtrar pels seus xecs.

for $check in collection("CLASSICMODELS_BD")//check
where $check/customer/customerNumber = (
  for $c in collection("CLASSICMODELS_BD")//customer
  where $c/customerName = "Atelier graphique"
  return $c/@customerNumber
)
return $check/@number
2.14. Retorna els imports (amount) dels xecs associats a clients amb cognoms King o Schmitt. Ordena els imports de major a menor.
for $p in collection("CLASSICMODELS_BD")//check
let $cNumber := $p/customer/@customerNumber
let $cliente := collection("CLASSICMODELS_BD")//customer[@customerNumber = $cNumber]
where $cliente/contact/contactLastName = "King" 
   or $cliente/contact/contactLastName = "Schmitt"
order by xs:double($p/amount) descending
return $p/amount

2.15. Retorna el número (number) i l'import (amount) dels xecs associats a clients gestionats pels empleats amb cognoms Fixter o King. Ordena els resultats de major a menor import.

for $p in collection("CLASSICMODELS_BD")//check
let $repID := $p/customer/salesRepEmployeeNumber
for $e in collection("CLASSICMODELS_BD")//employee
where $e/@employeeNumber = $repID 
  and ($e/lastName = "Fixter" or $e/lastName = "King")
order by xs:decimal($p/amount) descending
return concat("ID: ", $p/@number, ", Quantitat: ", $p/amount) 
