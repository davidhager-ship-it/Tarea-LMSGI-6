2.1. Quin són els noms dels clients que tenen un límit de crèdit (creditLimit) entre 1160 i 1165 $? descartar explícitament els valors NULL. 
distinct-values(
  for $c in collection("CLASSICMODELS_BD")//check/customer
  let $limit := xs:decimal($c/creditLimit)
  where $limit >= 1160 and $limit <= 1165 and $c/creditLimit != "NULL"
  return $c/customerName/text()
)

2.2. Quants clients tenen un límit de crèdit (creditLimit) superior a 1600?
count(
  for $c in collection("CLASSICMODELS_BD")/customers/customer
  let $limit := number($c/creditLimit)
  where $limit > 1600
  return $c
)
